# Generated by Cargo
# will have compiled files and executables
debug
target

# Generated by npm/Vite/wasm-pack
node_modules/
web/dist/
web/pkg/

# Local OS/editor files
.DS_Store

# Python cache artifacts from local helper scripts
__pycache__/
*.py[cod]

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Local real-paper corpus used for manual smoke/performance checks
sample-corpus/

# Local web-demo uploads and extracted paper sources
.cache/

# Local paper samples used during development
tmp/
tmp/

# Local Hermes/Codex run artifacts
.cache/

# Local archives of scratch notes and run reports
.cache/

# Validation pipeline run artifacts
llm_validation/runs/
llm_validation/baseline/

# Fine-tuned model weights and large generated datasets
data/ml/models/
data/ml/suggest_dataset/
data/ml/log_diagnosis_dataset/

# Local comparative analysis notes
notes.md

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/
